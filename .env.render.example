# Minimal .env para Render (Docker + Postgres)
# Copie os valores para as variáveis de ambiente do serviço Web no painel do Render.
# Substitua os placeholders entre <> pelo seus valores reais.

DOCKER_ENV=true
SERVER_NAME=evolution
SERVER_TYPE=http
# No Render defina `SERVER_PORT` para `$PORT` (preferível). Se não for possível, use o Start Command descrito em RENDER_DEPLOY.md.
SERVER_PORT=8080
SERVER_URL=https://<your-service>.onrender.com
CORS_ORIGIN=*
CORS_METHODS=POST,GET,PUT,DELETE
CORS_CREDENTIALS=true

# --- Banco de dados (Render Managed Postgres) ---
DATABASE_PROVIDER=postgresql
# Cole a Primary DB Connection String fornecida pelo Render (ex.: postgres://user:pass@host:5432/dbname)
DATABASE_URL=postgres://<USER>:<PASSWORD>@<HOST>:5432/<DB_NAME>
# A aplicação lê DATABASE_CONNECTION_URI; os scripts de migração esperam DATABASE_URL — defina ambos iguais.
DATABASE_CONNECTION_URI=postgres://<USER>:<PASSWORD>@<HOST>:5432/<DB_NAME>
DATABASE_CONNECTION_CLIENT_NAME=evolution

# Disable Redis (não obrigatório)
CACHE_REDIS_ENABLED=false
CACHE_LOCAL_ENABLED=true

# Chave de API global (troque por um valor seguro)
AUTHENTICATION_API_KEY=change_this_api_key

WEBSOCKET_ENABLED=true
TELEMETRY_ENABLED=false
LOG_COLOR=true
LANGUAGE=pt-BR

# Opcional: SENTRY_DSN=, S3 configs, etc.
